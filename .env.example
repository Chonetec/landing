# Copia este archivo como `.env` y completa los valores reales.
# `.env` está en .gitignore y NUNCA debe subirse a GitHub.

# Endpoint del formulario de contacto (Formspree).
# 1. Crea una cuenta gratis en https://formspree.io
# 2. Crea un formulario nuevo y copia su ID (ej. https://formspree.io/f/abcdwxyz)
# 3. Pega la URL completa aquí y también en las variables de entorno de Vercel.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/TU_FORM_ID
